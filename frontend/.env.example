# Copie este arquivo para .env.local e preencha os valores
# Gere AUTH_SECRET com: openssl rand -base64 32
AUTH_SECRET=
# URL acessível pelo NAVEGADOR do usuário.
# Como o browser está fora da rede Docker, ele enxerga o backend via 'localhost'.
NEXT_PUBLIC_API_URL=http://localhost:8000
# URL acessível pelo SERVIDOR do Next.js (Server-side).
# Como o container do Next está dentro da rede Docker, ele usa o nome do serviço 'backend'.
API_INTERNAL_URL=http://backend:8000